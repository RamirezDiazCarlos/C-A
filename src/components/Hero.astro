---
import HeroInteractive from "./HeroInteractive";
---

<section
  id="inicio"
  class="relative min-h-screen flex items-center justify-center overflow-hidden"
  style="background-color: #0F172A;"
>
  <!-- Imagen de fondo con overlay -->
  <div
    class="absolute inset-0 z-0"
    style="
      background-image:
        linear-gradient(to bottom, rgba(15,23,42,0.72) 0%, rgba(27,42,74,0.82) 100%),
        url('/Hero.webp');
      background-size: cover;
      background-position: center;
      background-repeat: no-repeat;
    "
  ></div>

  <!-- Patrón de grilla industrial -->
  <div
    class="absolute inset-0 z-0 opacity-5"
    style="
      background-image:
        repeating-linear-gradient(0deg, #6B7280 0px, #6B7280 1px, transparent 1px, transparent 60px),
        repeating-linear-gradient(90deg, #6B7280 0px, #6B7280 1px, transparent 1px, transparent 60px);
    "
  ></div>

  <!-- Spotlight SVG -->
  <svg
    class="spotlight pointer-events-none absolute z-[1] h-[169%] w-[138%] lg:w-[84%] opacity-0"
    xmlns="http://www.w3.org/2000/svg"
    viewBox="0 0 3787 2842"
    fill="none"
  >
    <g filter="url(#spotfilter)">
      <ellipse
        cx="1924.71"
        cy="273.501"
        rx="1924.71"
        ry="273.501"
        transform="matrix(-0.822377 -0.568943 -0.568943 0.822377 3631.88 2291.09)"
        fill="#D97706"
        fill-opacity="0.15"
      ></ellipse>
    </g>
    <defs>
      <filter
        id="spotfilter"
        x="0.860352"
        y="0.838989"
        width="3785.16"
        height="2840.26"
        filterUnits="userSpaceOnUse"
        color-interpolation-filters="sRGB"
      >
        <feFlood flood-opacity="0" result="BackgroundImageFix"></feFlood>
        <feBlend mode="normal" in="SourceGraphic" in2="BackgroundImageFix" result="shape"></feBlend>
        <feGaussianBlur stdDeviation="151" result="effect1_foregroundBlur"></feGaussianBlur>
      </filter>
    </defs>
  </svg>

  <!-- Etiqueta + Headline + CTAs (React island) -->
  <div class="relative z-10 max-w-5xl mx-auto px-6 text-center">
    <!-- Etiqueta superior -->
    <p
      class="inline-block mb-6 px-4 py-1.5 text-xs font-bold tracking-widest uppercase"
      style="
        background-color: rgba(217,119,6,0.15);
        color: #D97706;
        border: 1px solid rgba(217,119,6,0.4);
        border-radius: 2px;
      "
    >
      Clavos y Alambres Rosario · Mayor y Menor
    </p>

    <!-- Headline + subheadline + CTAs animados -->
    <HeroInteractive client:idle />

    <!-- Indicadores de confianza -->
    <div
      class="mt-14 flex flex-col sm:flex-row gap-6 justify-center items-center"
      style="color: #6B7280; font-size: 0.85rem; font-weight: 600; letter-spacing: 0.05em; text-transform: uppercase;"
    >
      <span>✓ Gran variedad de productos</span>
      <span class="hidden sm:block" style="color: #1B2A4A;">|</span>
      <span>✓ Factura A y B</span>
      <span class="hidden sm:block" style="color: #1B2A4A;">|</span>
      <span>✓ Envíos a todo el país</span>
    </div>
  </div>

  <!-- Scroll indicator -->
  <a
    href="#productos"
    class="absolute bottom-8 left-1/2 -translate-x-1/2 z-10 flex flex-col items-center gap-2"
    style="color: #6B7280;"
    aria-label="Ver más"
  >
    <span style="font-size: 0.7rem; letter-spacing: 0.1em; text-transform: uppercase;">Ver más</span>
    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
      <path d="M12 5v14M5 12l7 7 7-7"/>
    </svg>
  </a>
</section>
