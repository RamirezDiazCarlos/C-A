---
import HighlightsGrid from "./HighlightsGrid";
---

<section id="nosotros" style="background-color: #0F172A; padding: 6rem 0 0;">

  <!-- Header -->
  <div class="text-center px-6 max-w-2xl mx-auto mb-12">
    <p
      style="
        display: inline-block;
        margin-bottom: 1rem;
        padding: 0.25rem 1rem;
        font-size: 0.75rem;
        font-weight: 700;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        color: #D97706;
        background: rgba(217,119,6,0.1);
        border: 1px solid rgba(217,119,6,0.3);
        border-radius: 2px;
      "
    >
      Por qué elegirnos
    </p>
    <h2 class="section-title">
      El proveedor que tu empresa<br /><span>necesita</span>
    </h2>
    <p style="margin-top: 1rem; color: #9CA3AF; line-height: 1.7;">
      Abastecemos constructoras, contratistas, ferreterías
      y productores agropecuarios en todo el país.
    </p>
  </div>

  <!-- Grid de highlights -->
  <div class="max-w-6xl mx-auto px-6 pb-16">
    <HighlightsGrid client:visible />

    <!-- Barra de métricas -->
    <div class="metricas-bar">
      {[
        { valor: '+10 años', label: 'en el mercado' },
        { valor: '500+', label: 'clientes activos' },
        { valor: '48 hs', label: 'entrega máxima' },
        { valor: '100%', label: 'marcas líderes' },
      ].map((m) => (
        <div class="metrica-item">
          <div
            style="
              font-size: clamp(1.5rem, 3vw, 2.25rem);
              font-weight: 900;
              color: #D97706;
              line-height: 1;
              margin-bottom: 0.35rem;
            "
          >
            {m.valor}
          </div>
          <div style="font-size: 0.8rem; color: #6B7280; text-transform: uppercase; letter-spacing: 0.08em; font-weight: 600;">
            {m.label}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .metricas-bar {
    margin-top: 3rem;
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    border: 1px solid rgba(217,119,6,0.3);
    border-radius: 4px;
    overflow: hidden;
    background-color: rgba(27,42,74,0.4);
  }

  .metrica-item {
    text-align: center;
    padding: 1.75rem 1rem;
    border-right: 1px solid rgba(217,119,6,0.2);
  }

  .metrica-item:last-child {
    border-right: none;
  }

  @media (max-width: 640px) {
    .metricas-bar {
      grid-template-columns: repeat(2, 1fr);
    }

    .metrica-item:nth-child(2) {
      border-right: none;
    }

    .metrica-item:nth-child(1),
    .metrica-item:nth-child(2) {
      border-bottom: 1px solid rgba(217,119,6,0.2);
    }
  }
</style>
