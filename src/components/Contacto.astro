---
---

<section id="contacto" style="background-color: #111827; padding: 6rem 0;">
  <div class="max-w-6xl mx-auto px-6">
    <div
      style="
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 4rem;
        align-items: start;
      "
      class="contact-grid"
    >
      <!-- Columna izquierda: texto -->
      <div>
        <p
          style="
            display: inline-block;
            margin-bottom: 1rem;
            padding: 0.25rem 1rem;
            font-size: 0.75rem;
            font-weight: 700;
            letter-spacing: 0.12em;
            text-transform: uppercase;
            color: #D97706;
            background: rgba(217,119,6,0.1);
            border: 1px solid rgba(217,119,6,0.3);
            border-radius: 2px;
          "
        >
          Contacto
        </p>
        <h2 class="section-title" style="margin-bottom: 1.25rem;">
          Consultá por<br /><span>precios y stock</span>
        </h2>
        <p style="color: #9CA3AF; line-height: 1.8; margin-bottom: 2rem;">
          Completá el formulario y un vendedor especializado te responde
          a la brevedad con precios mayoristas y disponibilidad de stock.
          Sin compromiso.
        </p>

        <!-- Botones de contacto directo -->
        <div style="display: flex; flex-direction: column; gap: 0.75rem;">
          <a
            href="https://wa.me/5493476597438"
            target="_blank"
            rel="noopener noreferrer"
            style="
              display: flex;
              align-items: center;
              justify-content: center;
              gap: 0.6rem;
              padding: 0.85rem 1.5rem;
              background-color: #25D366;
              color: #fff;
              font-weight: 700;
              font-size: 0.95rem;
              text-decoration: none;
              border: 3px solid #25D366;
              border-radius: 4px;
              text-transform: uppercase;
              letter-spacing: 0.05em;
              transition: background-color 0.2s, color 0.2s;
            "
            onmouseenter="this.style.backgroundColor='transparent';this.style.color='#25D366'"
            onmouseleave="this.style.backgroundColor='#25D366';this.style.color='#fff'"
          >
            <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413Z"/></svg>
            Escribir por WhatsApp
          </a>

          <a
            href="tel:+5493476597438"
            style="
              display: flex;
              align-items: center;
              justify-content: center;
              gap: 0.6rem;
              padding: 0.85rem 1.5rem;
              background-color: transparent;
              color: #D97706;
              font-weight: 700;
              font-size: 0.95rem;
              text-decoration: none;
              border: 3px solid #D97706;
              border-radius: 4px;
              text-transform: uppercase;
              letter-spacing: 0.05em;
              transition: background-color 0.2s, color 0.2s;
            "
            onmouseenter="this.style.backgroundColor='#D97706';this.style.color='#fff'"
            onmouseleave="this.style.backgroundColor='transparent';this.style.color='#D97706'"
          >
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 13a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.56 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
            Llamar ahora
          </a>
        </div>

        <!-- Otros datos -->
        <div style="display: flex; flex-direction: column; gap: 1rem; margin-top: 0.5rem;">
          {[
            {
              icono: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#D97706" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>`,
              texto: 'clavosyalambres_rosario@hotmail.com',
              href: 'mailto:clavosyalambres_rosario@hotmail.com',
              label: 'Email',
            },
            {
              icono: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#D97706" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>`,
              texto: 'Rosario, Santa Fe, Argentina',
              href: null,
              label: 'Ubicación',
            },
          ].map((item) => (
            <div style="display: flex; align-items: flex-start; gap: 1rem;">
              <div
                style="
                  flex-shrink: 0;
                  width: 40px;
                  height: 40px;
                  background: rgba(217,119,6,0.1);
                  border: 1px solid rgba(217,119,6,0.3);
                  border-radius: 4px;
                  display: flex;
                  align-items: center;
                  justify-content: center;
                "
                set:html={item.icono}
              />
              <div>
                <p style="font-size: 0.75rem; color: #6B7280; text-transform: uppercase; letter-spacing: 0.08em; font-weight: 600; margin-bottom: 0.15rem;">
                  {item.label}
                </p>
                {item.href
                  ? <a href={item.href} style="color: #F9FAFB; font-weight: 600; text-decoration: none;">{item.texto}</a>
                  : <p style="color: #F9FAFB; font-weight: 600;">{item.texto}</p>
                }
              </div>
            </div>
          ))}
        </div>

        <!-- Redes sociales -->
        <div style="margin-top: 2rem;">
          <p style="font-size: 0.75rem; color: #6B7280; text-transform: uppercase; letter-spacing: 0.08em; font-weight: 600; margin-bottom: 0.75rem;">
            Seguinos
          </p>
          <div style="display: flex; gap: 0.75rem;">
            <a
              href="https://www.instagram.com/clavosyalambresrosario/"
              target="_blank"
              rel="noopener noreferrer"
              aria-label="Instagram"
              style="
                display: flex; align-items: center; gap: 0.5rem;
                padding: 0.6rem 1rem;
                background: rgba(217,119,6,0.07);
                border: 1px solid rgba(217,119,6,0.25);
                border-radius: 4px;
                color: #D97706;
                text-decoration: none;
                font-size: 0.8rem;
                font-weight: 700;
                letter-spacing: 0.04em;
                transition: background 0.15s, border-color 0.15s;
              "
              onmouseenter="this.style.background='rgba(217,119,6,0.18)';this.style.borderColor='rgba(217,119,6,0.5)'"
              onmouseleave="this.style.background='rgba(217,119,6,0.07)';this.style.borderColor='rgba(217,119,6,0.25)'"
            >
              <!-- Instagram icon -->
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <rect x="2" y="2" width="20" height="20" rx="5" ry="5"/>
                <circle cx="12" cy="12" r="4"/>
                <circle cx="17.5" cy="6.5" r="0.5" fill="currentColor"/>
              </svg>
              Instagram
            </a>

            <a
              href="https://www.facebook.com/p/Clavos-y-alambres-Rosario-100068872983625/"
              target="_blank"
              rel="noopener noreferrer"
              aria-label="Facebook"
              style="
                display: flex; align-items: center; gap: 0.5rem;
                padding: 0.6rem 1rem;
                background: rgba(217,119,6,0.07);
                border: 1px solid rgba(217,119,6,0.25);
                border-radius: 4px;
                color: #D97706;
                text-decoration: none;
                font-size: 0.8rem;
                font-weight: 700;
                letter-spacing: 0.04em;
                transition: background 0.15s, border-color 0.15s;
              "
              onmouseenter="this.style.background='rgba(217,119,6,0.18)';this.style.borderColor='rgba(217,119,6,0.5)'"
              onmouseleave="this.style.background='rgba(217,119,6,0.07)';this.style.borderColor='rgba(217,119,6,0.25)'"
            >
              <!-- Facebook icon -->
              <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
                <path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/>
              </svg>
              Facebook
            </a>
          </div>
        </div>

      </div>

      <!-- Columna derecha: formulario -->
      <div
        style="
          background-color: #1B2A4A;
          border: 1px solid rgba(107,114,128,0.25);
          border-top: 3px solid #D97706;
          border-radius: 4px;
          padding: 2.5rem;
        "
      >
        <form
          id="contact-form"
          style="display: flex; flex-direction: column; gap: 1.25rem;"
        >
          <!-- Nombre -->
          <div>
            <label
              for="nombre"
              style="display: block; font-size: 0.8rem; font-weight: 700; color: #9CA3AF; text-transform: uppercase; letter-spacing: 0.08em; margin-bottom: 0.4rem;"
            >
              Nombre y Apellido *
            </label>
            <input
              type="text"
              id="nombre"
              name="nombre"
              required
              placeholder="Juan García"
              style="
                width: 100%;
                padding: 0.75rem 1rem;
                background: rgba(15,23,42,0.6);
                border: 1px solid rgba(107,114,128,0.35);
                border-radius: 4px;
                color: #F9FAFB;
                font-size: 0.95rem;
                outline: none;
                transition: border-color 0.2s;
                box-sizing: border-box;
              "
              onfocus="this.style.borderColor='#D97706'"
              onblur="this.style.borderColor='rgba(107,114,128,0.35)'"
            />
          </div>

          <!-- Empresa -->
          <div>
            <label
              for="empresa"
              style="display: block; font-size: 0.8rem; font-weight: 700; color: #9CA3AF; text-transform: uppercase; letter-spacing: 0.08em; margin-bottom: 0.4rem;"
            >
              Empresa *
            </label>
            <input
              type="text"
              id="empresa"
              name="empresa"
              required
              placeholder="Constructora Ejemplo S.A."
              style="
                width: 100%;
                padding: 0.75rem 1rem;
                background: rgba(15,23,42,0.6);
                border: 1px solid rgba(107,114,128,0.35);
                border-radius: 4px;
                color: #F9FAFB;
                font-size: 0.95rem;
                outline: none;
                transition: border-color 0.2s;
                box-sizing: border-box;
              "
              onfocus="this.style.borderColor='#D97706'"
              onblur="this.style.borderColor='rgba(107,114,128,0.35)'"
            />
          </div>

          <!-- Teléfono -->
          <div>
            <label
              for="telefono"
              style="display: block; font-size: 0.8rem; font-weight: 700; color: #9CA3AF; text-transform: uppercase; letter-spacing: 0.08em; margin-bottom: 0.4rem;"
            >
              Teléfono / WhatsApp *
            </label>
            <input
              type="tel"
              id="telefono"
              name="telefono"
              required
              placeholder="03476 59-7438"
              style="
                width: 100%;
                padding: 0.75rem 1rem;
                background: rgba(15,23,42,0.6);
                border: 1px solid rgba(107,114,128,0.35);
                border-radius: 4px;
                color: #F9FAFB;
                font-size: 0.95rem;
                outline: none;
                transition: border-color 0.2s;
                box-sizing: border-box;
              "
              onfocus="this.style.borderColor='#D97706'"
              onblur="this.style.borderColor='rgba(107,114,128,0.35)'"
            />
          </div>

          <!-- Mensaje -->
          <div>
            <label
              for="mensaje"
              style="display: block; font-size: 0.8rem; font-weight: 700; color: #9CA3AF; text-transform: uppercase; letter-spacing: 0.08em; margin-bottom: 0.4rem;"
            >
              ¿Qué necesitás?
            </label>
            <textarea
              id="mensaje"
              name="mensaje"
              rows="4"
              placeholder="Ej: 500 kg de clavos galvanizados 2.5 pulgadas, 200 kg de alambre negro nro 17..."
              style="
                width: 100%;
                padding: 0.75rem 1rem;
                background: rgba(15,23,42,0.6);
                border: 1px solid rgba(107,114,128,0.35);
                border-radius: 4px;
                color: #F9FAFB;
                font-size: 0.95rem;
                outline: none;
                resize: vertical;
                transition: border-color 0.2s;
                box-sizing: border-box;
                font-family: inherit;
              "
              onfocus="this.style.borderColor='#D97706'"
              onblur="this.style.borderColor='rgba(107,114,128,0.35)'"
            ></textarea>
          </div>

          <!-- Submit -->
          <button
            type="submit"
            id="submit-btn"
            class="btn-accent"
            style="width: 100%; text-align: center; cursor: pointer; border: 3px solid #D97706;"
          >
            Enviar consulta
          </button>

          <p style="font-size: 0.75rem; color: #6B7280; text-align: center;">
            Te respondemos en menos de 24 hs hábiles.
          </p>

          <!-- Mensajes de estado -->
          <div id="form-success" style="display:none; padding: 1rem; background: rgba(34,197,94,0.1); border: 1px solid rgba(34,197,94,0.4); border-radius: 4px; color: #4ade80; text-align: center; font-weight: 600;">
            ¡Consulta enviada! Te respondemos a la brevedad.
          </div>
          <div id="form-error" style="display:none; padding: 1rem; background: rgba(239,68,68,0.1); border: 1px solid rgba(239,68,68,0.4); border-radius: 4px; color: #f87171; text-align: center; font-weight: 600;">
            Hubo un error al enviar. Por favor escribinos por WhatsApp.
          </div>
        </form>
      </div>
    </div>
  </div>
</section>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement;
  const btn = document.getElementById('submit-btn') as HTMLButtonElement;
  const successEl = document.getElementById('form-success') as HTMLElement;
  const errorEl = document.getElementById('form-error') as HTMLElement;

  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    btn.disabled = true;
    btn.textContent = 'Enviando...';
    successEl.style.display = 'none';
    errorEl.style.display = 'none';

    const data = Object.fromEntries(new FormData(form));

    try {
      const res = await fetch('/api/contact', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(data),
      });
      const json = await res.json();
      if (json.success) {
        successEl.style.display = 'block';
        form.reset();
      } else {
        errorEl.style.display = 'block';
      }
    } catch {
      errorEl.style.display = 'block';
    } finally {
      btn.disabled = false;
      btn.textContent = 'Enviar consulta';
    }
  });
</script>

