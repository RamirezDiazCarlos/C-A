---
import { productos, type Categoria } from '../data/productos';

const WA_NUMBER = '543476597438';

const categoriasOrden: Categoria[] = [
  'Alambres Rurales',
  'Alambre de Púas',
  'Alambres de Construcción',
  'Clavos',
  'Tejidos',
  'Accesorios',
  'Postes y Varillas',
];

const descripcionCategoria: Partial<Record<Categoria, string>> = {
  'Alambres Rurales': 'Alambres para campo Acindar Fortín e Invencible en medidas 16/14 y 17/15. Rollos de 1000 m. También manea, rienda, boyero y varillas galvanizadas. Precio mayorista y minorista.',
  'Alambre de Púas': 'Alambre de púa Super Bagual en rollos de 500 m. Alta resistencia para cercos rurales. Consulte precio por cantidad.',
  'Alambres de Construcción': 'Alambres galvanizados y recocidos Acindar para obras. Calibres n°12, n°14 y del 17 al 24. Venta por rollo, bobina y al peso.',
  'Clavos': 'Clavos punta París, espiralados, cajoneros y cabeza de plomo. Venta al por mayor y menor. Consulte medida y precio.',
  'Tejidos': 'Tejido romboidal y tejido chanchero en diferentes medidas y alturas. Consulte disponibilidad y precio mayorista.',
  'Postes y Varillas': 'Postes metálicos y varillas galvanizadas Acindar para cercos rurales. Diferentes medidas disponibles.',
};

const porCategoria = categoriasOrden
  .map((cat) => ({
    nombre: cat,
    items: productos.filter((p) => p.categoria === cat),
  }))
  .filter((g) => g.items.length > 0);
---

<section id="productos" style="background-color: #111827; padding: 6rem 0;">
  <div class="max-w-6xl mx-auto px-6">

    <!-- Encabezado -->
    <div class="mb-14 text-center">
      <p style="
        display: inline-block; margin-bottom: 1rem; padding: 0.25rem 1rem;
        font-size: 0.75rem; font-weight: 700; letter-spacing: 0.12em;
        text-transform: uppercase; color: #D97706;
        background: rgba(217,119,6,0.1); border: 1px solid rgba(217,119,6,0.3); border-radius: 2px;
      ">Catálogo de productos</p>
      <h2 class="section-title">Nuestros<br /><span>productos</span></h2>
      <p style="margin-top: 1rem; color: #9CA3AF; max-width: 520px; margin-left: auto; margin-right: auto; line-height: 1.7;">
        Vendemos al por mayor y al por menor. Consultá disponibilidad y precio para tu cantidad.
      </p>
    </div>

    <!-- Categorías -->
    <div style="display: flex; flex-direction: column; gap: 3.5rem;">
      {porCategoria.map((grupo) => (
        <div>
          <div style="margin-bottom: 1.25rem; padding-bottom: 0.75rem; border-bottom: 2px solid rgba(217,119,6,0.3);">
            <div style="display: flex; align-items: center; gap: 1rem;">
              <h3 style="font-size: 1.1rem; font-weight: 800; color: #F9FAFB; text-transform: uppercase; letter-spacing: 0.06em;">
                {grupo.nombre}
              </h3>
              <span style="font-size: 0.7rem; color: #6B7280; font-weight: 600; letter-spacing: 0.05em;">
                {grupo.items.length} {grupo.items.length === 1 ? 'producto' : 'productos'}
              </span>
            </div>
            {descripcionCategoria[grupo.nombre] && (
              <p style="margin: 0.4rem 0 0; font-size: 0.78rem; color: #6B7280; line-height: 1.6; max-width: 680px;">
                {descripcionCategoria[grupo.nombre]}
              </p>
            )}
          </div>

          <div class="productos-scroll">
            {grupo.items.map((prod) => (
              <div class="producto-card"
                onmouseenter="this.style.transform='translateY(-3px)';this.style.borderColor='rgba(217,119,6,0.4)'"
                onmouseleave="this.style.transform='translateY(0)';this.style.borderColor='rgba(107,114,128,0.2)'"
              >
                <!-- Imagen clickeable -->
                <button
                  class="img-trigger"
                  aria-label={`Ver imágenes de ${prod.nombre}`}
                  data-imagenes={JSON.stringify(prod.imagenes.map(img => `/Productos/${img}`))}
                  data-nombre={prod.nombre}
                  data-detalle={prod.detalle ?? ''}
                  data-wa={`https://wa.me/${WA_NUMBER}?text=${encodeURIComponent(prod.whatsapp)}`}
                >
                  {prod.imagenes[0] ? (
                    <img
                      src={`/Productos/${prod.imagenes[0]}`}
                      alt={prod.nombre}
                      loading="lazy"
                      style="width:100%;height:100%;object-fit:cover;object-position:center;display:block;"
                    />
                  ) : (
                    <div style="width:100%;height:100%;display:flex;align-items:center;justify-content:center;">
                      <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="rgba(107,114,128,0.3)" stroke-width="1.5">
                        <rect x="3" y="3" width="18" height="18" rx="2"/>
                        <circle cx="8.5" cy="8.5" r="1.5"/>
                        <polyline points="21 15 16 10 5 21"/>
                      </svg>
                    </div>
                  )}
                  <!-- Ícono lupa hover -->
                  <span class="zoom-hint" aria-hidden="true">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                      <circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/>
                      <line x1="11" y1="8" x2="11" y2="14"/><line x1="8" y1="11" x2="14" y2="11"/>
                    </svg>
                  </span>
                  {prod.imagenes.length > 1 && (
                    <span class="multi-badge" aria-hidden="true">{prod.imagenes.length} fotos</span>
                  )}
                </button>

                <!-- Texto + WA -->
                <div style="padding: 0.75rem; display: flex; align-items: flex-start; justify-content: space-between; gap: 0.5rem; flex: 1;">
                  <div style="flex: 1;">
                    <p style="font-size: 0.82rem; font-weight: 700; color: #F9FAFB; line-height: 1.35; margin: 0;">
                      {prod.nombre}
                    </p>
                    {prod.detalle && (
                      <p style="font-size: 0.72rem; color: #9CA3AF; margin: 0.2rem 0 0; line-height: 1.3;">
                        {prod.detalle}
                      </p>
                    )}
                  </div>
                  <a
                    href={`https://wa.me/${WA_NUMBER}?text=${encodeURIComponent(prod.whatsapp)}`}
                    target="_blank"
                    rel="noopener noreferrer"
                    aria-label={`Consultar por ${prod.nombre}`}
                    style="
                      flex-shrink: 0; display: flex; align-items: center; justify-content: center;
                      width: 2rem; height: 2rem;
                      background-color: rgba(37,211,102,0.12);
                      border: 1px solid rgba(37,211,102,0.3);
                      border-radius: 3px; color: #25D366; transition: background-color 0.15s;
                    "
                    onmouseenter="this.style.backgroundColor='rgba(37,211,102,0.25)'"
                    onmouseleave="this.style.backgroundColor='rgba(37,211,102,0.12)'"
                  >
                    <svg viewBox="0 0 32 32" width="15" height="15" fill="currentColor">
                      <path d="M16 0C7.163 0 0 7.163 0 16c0 2.825.738 5.476 2.031 7.775L0 32l8.469-2.007A15.93 15.93 0 0 0 16 32c8.837 0 16-7.163 16-16S24.837 0 16 0zm0 29.333a13.27 13.27 0 0 1-6.771-1.849l-.486-.289-5.027 1.191 1.214-4.903-.317-.503A13.236 13.236 0 0 1 2.667 16C2.667 8.637 8.637 2.667 16 2.667S29.333 8.637 29.333 16 23.363 29.333 16 29.333zm7.27-9.878c-.398-.199-2.355-1.162-2.72-1.295-.365-.133-.631-.199-.897.199-.266.398-1.029 1.295-1.261 1.561-.232.266-.465.299-.863.1-.398-.199-1.681-.619-3.2-1.974-1.183-1.054-1.981-2.356-2.213-2.754-.232-.398-.025-.613.174-.811.179-.178.398-.465.597-.697.199-.232.266-.398.398-.664.133-.266.066-.498-.033-.697-.099-.199-.897-2.162-1.229-2.96-.324-.778-.653-.673-.897-.686-.232-.012-.498-.015-.764-.015-.266 0-.697.1-1.062.498-.365.398-1.395 1.362-1.395 3.323s1.428 3.855 1.627 4.121c.199.266 2.81 4.291 6.808 6.018.951.411 1.693.656 2.272.839.954.303 1.823.26 2.51.158.766-.114 2.355-.963 2.687-1.893.332-.93.332-1.727.232-1.893-.099-.166-.365-.266-.763-.465z"/>
                    </svg>
                  </a>
                </div>
              </div>
            ))}
          </div>
        </div>
      ))}
    </div>

    <!-- CTA inferior -->
    <div class="mt-14 text-center">
      <p style="color: #6B7280; margin-bottom: 1.5rem; font-size: 0.95rem;">
        ¿Necesitás algo que no ves acá? Consultanos.
      </p>
      <a href="#contacto" class="btn-accent">Consultar precio y stock</a>
    </div>

  </div>
</section>

<!-- ── Modal de imágenes ─────────────────────────────────────────── -->
<div id="img-modal" role="dialog" aria-modal="true" aria-label="Visor de imagen">
  <div id="modal-backdrop"></div>
  <div id="modal-box">
    <!-- Cerrar -->
    <button id="modal-close" aria-label="Cerrar">
      <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
        <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
      </svg>
    </button>

    <!-- Imagen -->
    <div id="modal-img-wrap">
      <img id="modal-img" src="" alt="" />
      <!-- Flechas -->
      <button id="modal-prev" aria-label="Imagen anterior">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
          <polyline points="15 18 9 12 15 6"/>
        </svg>
      </button>
      <button id="modal-next" aria-label="Imagen siguiente">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
          <polyline points="9 18 15 12 9 6"/>
        </svg>
      </button>
    </div>

    <!-- Caption -->
    <div id="modal-caption">
      <div id="modal-info">
        <p id="modal-nombre"></p>
        <p id="modal-detalle"></p>
      </div>
      <div id="modal-footer">
        <div id="modal-dots"></div>
        <a id="modal-wa" href="" target="_blank" rel="noopener noreferrer">
          <svg viewBox="0 0 32 32" width="16" height="16" fill="currentColor">
            <path d="M16 0C7.163 0 0 7.163 0 16c0 2.825.738 5.476 2.031 7.775L0 32l8.469-2.007A15.93 15.93 0 0 0 16 32c8.837 0 16-7.163 16-16S24.837 0 16 0zm0 29.333a13.27 13.27 0 0 1-6.771-1.849l-.486-.289-5.027 1.191 1.214-4.903-.317-.503A13.236 13.236 0 0 1 2.667 16C2.667 8.637 8.637 2.667 16 2.667S29.333 8.637 29.333 16 23.363 29.333 16 29.333zm7.27-9.878c-.398-.199-2.355-1.162-2.72-1.295-.365-.133-.631-.199-.897.199-.266.398-1.029 1.295-1.261 1.561-.232.266-.465.299-.863.1-.398-.199-1.681-.619-3.2-1.974-1.183-1.054-1.981-2.356-2.213-2.754-.232-.398-.025-.613.174-.811.179-.178.398-.465.597-.697.199-.232.266-.398.398-.664.133-.266.066-.498-.033-.697-.099-.199-.897-2.162-1.229-2.96-.324-.778-.653-.673-.897-.686-.232-.012-.498-.015-.764-.015-.266 0-.697.1-1.062.498-.365.398-1.395 1.362-1.395 3.323s1.428 3.855 1.627 4.121c.199.266 2.81 4.291 6.808 6.018.951.411 1.693.656 2.272.839.954.303 1.823.26 2.51.158.766-.114 2.355-.963 2.687-1.893.332-.93.332-1.727.232-1.893-.099-.166-.365-.266-.763-.465z"/>
          </svg>
          Consultar por WhatsApp
        </a>
      </div>
    </div>
  </div>
</div>

<style>
  /* ── Cards ── */
  .productos-scroll {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1rem;
  }

  .producto-card {
    background-color: #1B2A4A;
    border: 1px solid rgba(107,114,128,0.2);
    border-radius: 4px;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    transition: transform 0.2s ease, border-color 0.2s ease;
  }

  /* Botón imagen */
  .img-trigger {
    position: relative;
    width: 100%;
    aspect-ratio: 4 / 3;
    background: #1B2A4A;
    border: none;
    padding: 0;
    cursor: zoom-in;
    overflow: hidden;
    display: block;
  }

  .zoom-hint {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(0,0,0,0.45);
    color: #fff;
    opacity: 0;
    transition: opacity 0.2s;
  }
  .img-trigger:hover .zoom-hint,
  .img-trigger:focus-visible .zoom-hint { opacity: 1; }

  .multi-badge {
    position: absolute;
    bottom: 7px;
    right: 7px;
    background: rgba(217,119,6,0.85);
    color: #fff;
    font-size: 0.6rem;
    font-weight: 800;
    padding: 0.15rem 0.45rem;
    border-radius: 2px;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    pointer-events: none;
  }

  /* Mobile: scroll horizontal */
  @media (max-width: 767px) {
    .productos-scroll {
      display: flex;
      overflow-x: auto;
      gap: 0.75rem;
      padding-bottom: 0.75rem;
      scroll-snap-type: x mandatory;
      -webkit-overflow-scrolling: touch;
      scrollbar-width: none;
    }
    .productos-scroll::-webkit-scrollbar { display: none; }
    .producto-card { flex: 0 0 220px; scroll-snap-align: start; }
  }

  @media (min-width: 768px) and (max-width: 1023px) {
    .productos-scroll { grid-template-columns: repeat(2, 1fr); }
  }

  /* ── Modal ── */
  #img-modal {
    display: none;
    position: fixed;
    inset: 0;
    z-index: 999;
    align-items: center;
    justify-content: center;
  }
  #img-modal.open { display: flex; }

  #modal-backdrop {
    position: absolute;
    inset: 0;
    background: rgba(0,0,0,0.88);
    cursor: pointer;
  }

  #modal-box {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    width: min(90vw, 860px);
    max-height: 90vh;
    background: #0F172A;
    border: 1px solid rgba(107,114,128,0.25);
    border-radius: 6px;
    overflow: hidden;
    box-shadow: 0 24px 64px rgba(0,0,0,0.7);
  }

  #modal-close {
    position: absolute;
    top: 10px;
    right: 10px;
    z-index: 10;
    background: rgba(15,23,42,0.85);
    border: 1px solid rgba(107,114,128,0.35);
    border-radius: 3px;
    color: #9CA3AF;
    width: 36px;
    height: 36px;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: color 0.15s, border-color 0.15s;
  }
  #modal-close:hover { color: #F9FAFB; border-color: rgba(107,114,128,0.6); }

  #modal-img-wrap {
    position: relative;
    width: 100%;
    background: #060D1A;
    display: flex;
    align-items: center;
    justify-content: center;
    max-height: 70vh;
    overflow: hidden;
  }

  #modal-img {
    max-width: 100%;
    max-height: 70vh;
    object-fit: contain;
    display: block;
    transition: opacity 0.2s;
  }

  #modal-prev, #modal-next {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    background: rgba(15,23,42,0.75);
    border: 1px solid rgba(107,114,128,0.3);
    border-radius: 3px;
    color: #D1D5DB;
    width: 40px;
    height: 40px;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: background 0.15s, color 0.15s;
  }
  #modal-prev { left: 10px; }
  #modal-next { right: 10px; }
  #modal-prev:hover, #modal-next:hover { background: rgba(217,119,6,0.8); color: #fff; }
  #modal-prev[hidden], #modal-next[hidden] { display: none; }

  #modal-caption {
    padding: 0.9rem 1.1rem;
    border-top: 1px solid rgba(107,114,128,0.15);
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    flex-wrap: wrap;
  }

  #modal-info { flex: 1; min-width: 0; }
  #modal-nombre {
    font-size: 0.9rem;
    font-weight: 700;
    color: #F9FAFB;
    margin: 0;
  }
  #modal-detalle {
    font-size: 0.78rem;
    color: #9CA3AF;
    margin: 0.15rem 0 0;
  }

  #modal-footer {
    display: flex;
    align-items: center;
    gap: 1rem;
    flex-shrink: 0;
  }

  #modal-dots {
    display: flex;
    gap: 5px;
    align-items: center;
  }
  #modal-dots .mdot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: rgba(107,114,128,0.5);
    transition: background 0.2s, transform 0.2s;
    cursor: pointer;
    border: none;
    padding: 0;
  }
  #modal-dots .mdot.active {
    background: #D97706;
    transform: scale(1.3);
  }

  #modal-wa {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.5rem 0.9rem;
    background: rgba(37,211,102,0.12);
    border: 1px solid rgba(37,211,102,0.3);
    border-radius: 3px;
    color: #25D366;
    font-size: 0.78rem;
    font-weight: 700;
    text-decoration: none;
    white-space: nowrap;
    transition: background 0.15s;
  }
  #modal-wa:hover { background: rgba(37,211,102,0.25); }

  @media (max-width: 480px) {
    #modal-wa span { display: none; }
    #modal-caption { flex-direction: column; align-items: flex-start; }
  }
</style>

<script>
  const modal        = document.getElementById('img-modal')!;
  const backdrop     = document.getElementById('modal-backdrop')!;
  const modalImg     = document.getElementById('modal-img') as HTMLImageElement;
  const modalPrev    = document.getElementById('modal-prev') as HTMLButtonElement;
  const modalNext    = document.getElementById('modal-next') as HTMLButtonElement;
  const modalDots    = document.getElementById('modal-dots')!;
  const modalNombre  = document.getElementById('modal-nombre')!;
  const modalDetalle = document.getElementById('modal-detalle')!;
  const modalWa      = document.getElementById('modal-wa') as HTMLAnchorElement;
  const modalClose   = document.getElementById('modal-close') as HTMLButtonElement;

  let imagenes: string[] = [];
  let current = 0;

  function updateArrows() {
    modalPrev.style.display = (imagenes.length <= 1 || current === 0) ? 'none' : 'flex';
    modalNext.style.display = (imagenes.length <= 1 || current === imagenes.length - 1) ? 'none' : 'flex';
  }

  function updateDots() {
    modalDots.querySelectorAll<HTMLElement>('.mdot').forEach((d, i) =>
      d.classList.toggle('active', i === current)
    );
  }

  function goTo(index: number) {
    current = Math.max(0, Math.min(index, imagenes.length - 1));
    modalImg.src = imagenes[current];
    updateArrows();
    updateDots();
  }

  function buildDots() {
    modalDots.innerHTML = '';
    if (imagenes.length <= 1) return;
    imagenes.forEach((_, i) => {
      const btn = document.createElement('button');
      btn.className = 'mdot' + (i === current ? ' active' : '');
      btn.setAttribute('aria-label', `Imagen ${i + 1}`);
      btn.addEventListener('click', () => goTo(i));
      modalDots.appendChild(btn);
    });
  }

  function openModal(imgs: string[], nombre: string, detalle: string, wa: string) {
    imagenes = imgs;
    current  = 0;
    modalNombre.textContent  = nombre;
    modalDetalle.textContent = detalle;
    modalWa.href             = wa;
    modalImg.src             = imgs[0];
    buildDots();
    updateArrows();
    modal.classList.add('open');
    document.body.style.overflow = 'hidden';
  }

  function closeModal() {
    modal.classList.remove('open');
    document.body.style.overflow = '';
  }

  // Abrir desde las cards
  document.querySelectorAll<HTMLButtonElement>('.img-trigger').forEach((btn) => {
    btn.addEventListener('click', () => {
      const imgs    = JSON.parse(btn.dataset.imagenes ?? '[]') as string[];
      const nombre  = btn.dataset.nombre  ?? '';
      const detalle = btn.dataset.detalle ?? '';
      const wa      = btn.dataset.wa      ?? '';
      if (imgs.length === 0) return;
      openModal(imgs, nombre, detalle, wa);
    });
  });

  modalClose.addEventListener('click', closeModal);
  backdrop.addEventListener('click', closeModal);
  modalPrev.addEventListener('click', () => goTo(current - 1));
  modalNext.addEventListener('click', () => goTo(current + 1));

  document.addEventListener('keydown', (e) => {
    if (!modal.classList.contains('open')) return;
    if (e.key === 'Escape')      closeModal();
    if (e.key === 'ArrowLeft')   goTo(current - 1);
    if (e.key === 'ArrowRight')  goTo(current + 1);
  });

  // Swipe mobile
  let touchStartX = 0;
  modalImg.addEventListener('touchstart', (e) => { touchStartX = e.touches[0].clientX; }, { passive: true });
  modalImg.addEventListener('touchend', (e) => {
    const diff = touchStartX - e.changedTouches[0].clientX;
    if (Math.abs(diff) < 40) return;
    goTo(diff > 0 ? current + 1 : current - 1);
  });
</script>
