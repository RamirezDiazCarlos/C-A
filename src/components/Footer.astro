---
const currentYear = new Date().getFullYear();
---

<footer style="background-color: #060D1A; border-top: 1px solid rgba(107,114,128,0.15); padding: 4rem 0 2rem;">
  <div class="max-w-6xl mx-auto px-6">
    <!-- Fila superior -->
    <div
      style="
        display: grid;
        grid-template-columns: 2fr 1fr 1fr;
        gap: 3rem;
        margin-bottom: 3rem;
      "
      class="footer-grid"
    >
      <!-- Columna 1: Marca -->
      <div>
        <div style="margin-bottom: 1.25rem;">
          <span
            style="
              font-size: 1.5rem;
              font-weight: 900;
              color: #F9FAFB;
              letter-spacing: -0.03em;
            "
          >
            Clavos y Alambres <span style="color: #D97706;">Rosario</span>
          </span>
        </div>
        <p style="color: #6B7280; font-size: 0.9rem; line-height: 1.8; max-width: 320px;">
          Distribuidora de clavos, alambres y accesorios metálicos
          con sede en Rosario, Santa Fe. Vendemos al por mayor y al por menor,
          con envíos a todo el país.
        </p>
        <!-- Redes sociales -->
        <div style="display: flex; gap: 0.75rem; margin-top: 1.5rem;">
          {[
            {
              label: 'WhatsApp',
              href: 'https://wa.me/5493476597438',
              icono: `<svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413Z"/></svg>`,
            },
            {
              label: 'Instagram',
              href: 'https://www.instagram.com/clavosyalambresrosario/',
              icono: `<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/></svg>`,
            },
            {
              label: 'Facebook',
              href: 'https://www.facebook.com/p/Clavos-y-alambres-Rosario-100068872983625/',
              icono: `<svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>`,
            },
          ].map((red) => (
            <a
              href={red.href}
              target="_blank"
              rel="noopener noreferrer"
              aria-label={red.label}
              style="
                display: flex;
                align-items: center;
                justify-content: center;
                width: 38px;
                height: 38px;
                background: rgba(27,42,74,0.6);
                border: 1px solid rgba(107,114,128,0.25);
                border-radius: 4px;
                color: #9CA3AF;
                transition: color 0.2s, border-color 0.2s, background 0.2s;
              "
              onmouseenter="this.style.color='#D97706';this.style.borderColor='rgba(217,119,6,0.5)'"
              onmouseleave="this.style.color='#9CA3AF';this.style.borderColor='rgba(107,114,128,0.25)'"
              set:html={red.icono}
            />
          ))}
        </div>
      </div>

      <!-- Columna 2: Productos -->
      <div>
        <h4
          style="
            font-size: 0.75rem;
            font-weight: 700;
            color: #D97706;
            text-transform: uppercase;
            letter-spacing: 0.1em;
            margin-bottom: 1rem;
          "
        >
          Productos
        </h4>
        <ul style="list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 0.5rem;">
          {['Clavos', 'Alambres', 'Rollos de malla', 'Grampas y accesorios', 'Bulones y tuercas'].map((item) => (
            <li>
              <a
                href="#productos"
                style="color: #6B7280; font-size: 0.9rem; text-decoration: none; transition: color 0.2s;"
                onmouseenter="this.style.color='#D97706'"
                onmouseleave="this.style.color='#6B7280'"
              >
                {item}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Columna 3: Navegación -->
      <div>
        <h4
          style="
            font-size: 0.75rem;
            font-weight: 700;
            color: #D97706;
            text-transform: uppercase;
            letter-spacing: 0.1em;
            margin-bottom: 1rem;
          "
        >
          Navegación
        </h4>
        <ul style="list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 0.5rem;">
          {[
            { label: 'Inicio', href: '#inicio' },
            { label: 'Productos', href: '#productos' },
            { label: 'Por qué nosotros', href: '#nosotros' },
            { label: 'Contacto', href: '#contacto' },
          ].map((link) => (
            <li>
              <a
                href={link.href}
                style="color: #6B7280; font-size: 0.9rem; text-decoration: none; transition: color 0.2s;"
                onmouseenter="this.style.color='#D97706'"
                onmouseleave="this.style.color='#6B7280'"
              >
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>
    </div>

    <!-- Línea divisoria -->
    <div style="border-top: 1px solid rgba(107,114,128,0.15); padding-top: 2rem; display: flex; flex-wrap: wrap; justify-content: space-between; align-items: center; gap: 1rem;">
      <p style="color: #374151; font-size: 0.8rem;">
        © {currentYear} Clavos y Alambres Rosario. Todos los derechos reservados.
      </p>
      <p style="color: #374151; font-size: 0.8rem;">
        Rosario, Santa Fe, Argentina
      </p>
    </div>
  </div>
</footer>

