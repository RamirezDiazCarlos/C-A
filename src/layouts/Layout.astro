---
import '../styles/global.css';
import Nav from '../components/Nav.astro';
import { productos } from '../data/productos';

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
}

const {
  title = 'Clavos y Alambres Rosario',
  description = 'Venta de alambres Acindar, clavos, tejidos, postes y accesorios para campo y construcción. Mayorista y minorista. Envíos a todo el país. Consultá precio y stock.',
  ogImage = '/OG.webp',
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const siteURL = 'https://clavosyalambres.com.ar';

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "Store",
  "name": "Clavos y Alambres Rosario",
  "url": siteURL,
  "telephone": "+5493476597438",
  "email": "clavosyalambresrosario@hotmail.com",
  "description": "Venta de alambres Acindar, clavos, tejidos, postes y accesorios para campo y construcción. Mayorista y minorista con envíos a todo el país.",
  "areaServed": "AR",
  "priceRange": "$$",
  "hasOfferCatalog": {
    "@type": "OfferCatalog",
    "name": "Catálogo de productos",
    "itemListElement": productos.map((p, i) => {
      const esAcindar = p.nombre.toLowerCase().includes('acindar') || (p.detalle ?? '').toLowerCase().includes('acindar');
      return {
        "@type": "ListItem",
        "position": i + 1,
        "item": {
          "@type": "Product",
          "name": p.nombre,
          "description": p.detalle ? `${p.nombre} — ${p.detalle}` : `${p.nombre}. Disponible en Clavos y Alambres Rosario.`,
          "image": `${siteURL}/Productos/${p.imagenes[0]}`,
          "url": `${siteURL}/#productos`,
          ...(esAcindar ? { "brand": { "@type": "Brand", "name": "Acindar" } } : {}),
          "offers": {
            "@type": "Offer",
            "priceCurrency": "ARS",
            "price": "0",
            "availability": "https://schema.org/InStock",
            "url": `${siteURL}/#contacto`,
            "shippingDetails": {
              "@type": "OfferShippingDetails",
              "shippingRate": { "@type": "MonetaryAmount", "currency": "ARS", "value": "0" },
              "shippingDestination": { "@type": "DefinedRegion", "addressCountry": "AR" },
              "deliveryTime": {
                "@type": "ShippingDeliveryTime",
                "handlingTime": { "@type": "QuantitativeValue", "minValue": 0, "maxValue": 2, "unitCode": "DAY" },
                "transitTime": { "@type": "QuantitativeValue", "minValue": 1, "maxValue": 5, "unitCode": "DAY" }
              }
            },
            "hasMerchantReturnPolicy": {
              "@type": "MerchantReturnPolicy",
              "applicableCountry": "AR",
              "returnPolicyCategory": "https://schema.org/MerchantReturnNotPermitted"
            }
          }
        }
      };
    }),
  },
};
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />

    <!-- Google Search Console -->
    <meta name="google-site-verification" content="iCijO_pY654A3jRAqcugnF0veyA8A8LcZfCfLeMKVSk" />

    <!-- SEO básico -->
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={new URL(ogImage, Astro.site)} />
    <meta property="og:locale" content="es_AR" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={new URL(ogImage, Astro.site)} />

    <!-- Favicon -->
    <link rel="icon" type="image/x-icon" href="/favicon/favicon.ico" />
    <link rel="icon" type="image/svg+xml" href="/favicon/favicon.svg" />
    <link rel="icon" type="image/png" sizes="96x96" href="/favicon/favicon-96x96.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/favicon/apple-touch-icon.png" />
    <link rel="manifest" href="/favicon/site.webmanifest" />

    <!-- JSON-LD -->
    <script is:inline type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

    <!-- Google Fonts: Barlow -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Barlow:wght@400;500;600;700;800;900&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <Nav />
    <slot />
  </body>
</html>
